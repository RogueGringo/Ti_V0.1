{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SheavedVerdict",
  "description": "L3 artifact — sheaf consistency check with kernel dimension and obstruction report.",
  "type": "object",
  "required": ["sections", "kernel_dim", "obstructions", "verdict", "layer"],
  "properties": {
    "layer": { "const": "L3" },
    "timestamp": { "type": "string", "format": "date-time" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "compatibility"],
        "properties": {
          "title": { "type": "string" },
          "content": { "type": "string" },
          "source_cluster": { "type": "integer" },
          "coherence_score": { "type": "number" },
          "compatibility": { "type": "string", "enum": ["CONSISTENT", "INCOMPATIBLE"] }
        }
      }
    },
    "kernel_dim": {
      "type": "integer",
      "description": "ker(L_F) — number of globally consistent sections"
    },
    "obstructions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["section_a", "section_b", "incompatibility"],
        "properties": {
          "section_a": { "type": "integer" },
          "section_b": { "type": "integer" },
          "incompatibility": { "type": "string" }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["ON_SHELL", "OFF_SHELL"] },
    "verdict_reason": { "type": "string" }
  }
}
