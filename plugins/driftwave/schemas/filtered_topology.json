{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FilteredTopology",
  "description": "L1 artifact — persistent clusters with barcode, distances, and routing decision.",
  "type": "object",
  "required": ["clusters", "barcode", "noise", "routing", "layer"],
  "properties": {
    "layer": { "const": "L1" },
    "timestamp": { "type": "string", "format": "date-time" },
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "members", "bar_length"],
        "properties": {
          "id": { "type": "integer" },
          "label": { "type": "string" },
          "members": { "type": "array", "items": { "type": "string" } },
          "bar_length": { "type": "number", "description": "Persistence — longer = more real" },
          "centroid_description": { "type": "string" }
        }
      }
    },
    "barcode": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["birth", "death", "dimension"],
        "properties": {
          "birth": { "type": "number" },
          "death": { "type": "number" },
          "dimension": { "type": "integer" }
        }
      }
    },
    "noise": { "type": "array", "items": { "type": "string" } },
    "distances": {
      "type": "array",
      "items": { "type": "array", "items": { "type": "number" } },
      "description": "Pairwise distance matrix for visualization"
    },
    "routing": { "type": "string", "enum": ["ASCEND", "REPROBE", "SPLIT"] },
    "routing_reason": { "type": "string" }
  }
}
