{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RawCloud",
  "description": "L0 artifact — raw artifact scan with no interpretation. Entropy gate rejects low-variance inputs.",
  "type": "object",
  "required": ["files", "git_state", "docs", "entropy", "layer"],
  "properties": {
    "layer": { "const": "L0" },
    "timestamp": { "type": "string", "format": "date-time" },
    "entropy": {
      "type": "number",
      "description": "Variance across artifacts. <0.1 = REJECT (no differentiation)"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "language", "size_bytes"],
        "properties": {
          "path": { "type": "string" },
          "content_hash": { "type": "string" },
          "language": { "type": "string" },
          "size_bytes": { "type": "integer" },
          "staleness_days": { "type": "number" }
        }
      }
    },
    "git_state": {
      "type": "object",
      "properties": {
        "branch": { "type": "string" },
        "recent_commits": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "hash": { "type": "string" },
              "message": { "type": "string" },
              "files_changed": { "type": "integer" }
            }
          }
        },
        "dirty_files": { "type": "array", "items": { "type": "string" } }
      }
    },
    "docs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "staleness_days": { "type": "number" },
          "type": { "type": "string", "enum": ["spec", "plan", "log", "theory", "guide", "readme"] }
        }
      }
    }
  }
}
