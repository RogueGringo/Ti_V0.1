{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SynthesisMap",
  "description": "L2 artifact — design sections with coherence scores, Gini trajectory, and H₁ loop detection.",
  "type": "object",
  "required": ["sections", "loops", "trajectory", "routing", "layer"],
  "properties": {
    "layer": { "const": "L2" },
    "timestamp": { "type": "string", "format": "date-time" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "content", "source_cluster", "coherence_score", "gini_slope"],
        "properties": {
          "title": { "type": "string" },
          "content": { "type": "string" },
          "source_cluster": { "type": "integer" },
          "coherence_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "gini_slope": { "type": "number" }
        }
      }
    },
    "loops": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feature", "sections", "status"],
        "properties": {
          "feature": { "type": "string" },
          "sections": { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 },
          "status": { "type": "string", "enum": ["OPEN", "CLOSED"] }
        }
      }
    },
    "trajectory": { "type": "array", "items": { "type": "number" } },
    "routing": { "type": "string", "enum": ["ASCEND", "REPROBE", "SPLIT"] }
  }
}
